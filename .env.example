SMTP_HOST=mail.noviousglobal.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@noviousglobal.com
SMTP_PASS=
MAIL_FROM=info@noviousglobal.com
CONTACT_TO=info@noviousglobal.com
# Port the backend listens on (Passenger overrides this)
PORT=3001
# NPROC hardening — also set these in cPanel "Setup Node.js App → Environment variables"
UV_THREADPOOL_SIZE=1
NODE_OPTIONS=--max-old-space-size=256
# Allowed frontend origin(s) for CORS, comma-separated.
# Leave blank during local development to allow all origins.
CORS_ORIGIN=https://ecs.ingeniousc.com
# ────────────────────────────────────────────────────────────────
# Frontend (Vite) — the URL the contact form POSTs to.
# Must be prefixed with VITE_ to be exposed to the browser build.
# Static hosting (recommended, no Node): /contact.php
# Node/app.js fallback:                  /api/contact
# ────────────────────────────────────────────────────────────────
VITE_CONTACT_API_URL=/contact.php
