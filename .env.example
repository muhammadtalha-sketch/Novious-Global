SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=
SMTP_USER=info@noviousglobal.com
SMTP_PASS=
MAIL_FROM=info@noviousglobal.com
CONTACT_TO=info@noviousglobal.com
# Port the backend listens on
PORT=3001
# Allowed frontend origin(s) for CORS, comma-separated.
# e.g. https://noviousglobal.com,https://www.noviousglobal.com
# Leave blank during local development to allow all origins.
CORS_ORIGIN=
# ────────────────────────────────────────────────────────────────
# Frontend (Vite) — the URL the contact form POSTs to.
# Must be prefixed with VITE_ to be exposed to the browser build.
# Local dev default is http://localhost:3001/api/contact.
# In production set this to your deployed backend URL.
# ────────────────────────────────────────────────────────────────
VITE_CONTACT_API_URL=http://localhost:3001/api/contact